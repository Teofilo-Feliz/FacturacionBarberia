@model UsuarioRequest

@section Styles
{
    <link rel="stylesheet"
          href="~/css/usuario.css" />
}

<div class="card">

    <div class="card-header">

        <h2>Registrar Usuario</h2>

        <p>
            Gestión de usuarios del sistema
        </p>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="success-message">

            @TempData["Success"]

        </div>
    }

    <div asp-validation-summary="All"
         class="validation-errors">
    </div>

    <form asp-action="Crear"
          method="post">

        <div class="form-group">

            <label>Nombre</label>

            <input asp-for="Nombre"
                   class="form-control" />

        </div>

        <div class="form-group">

            <label>Usuario</label>

            <input asp-for="UserName"
                   class="form-control" />

        </div>

        <div class="form-group">

            <label>Contraseña</label>

            <input asp-for="Password"
                   type="password"
                   class="form-control" />

        </div>

        <div class="form-group">

            <label>Rol</label>

            <select asp-for="Rol"
                    class="form-control">

                <option value="1">
                    Administrador
                </option>

                <option value="2">
                    Cajero
                </option>

            </select>

        </div>

        <div class="form-group">

            <label>Estado</label>

            <select asp-for="Estado"
                    class="form-control">

                <option value="1">
                    Activo
                </option>

                <option value="2">
                    Inactivo
                </option>

            </select>

        </div>

        <button type="submit"
                class="btn-primary">

            Guardar Usuario

        </button>

    </form>

</div>