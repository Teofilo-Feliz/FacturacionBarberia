@model EditarClienteRequest

@using FacturacionBarberia.Domain.Models.Enum

@section Styles
{
    <link rel="stylesheet"
          href="~/css/editar.css" />
}

<div class="edit-container">

    <div class="card">

        <div class="card-header">

            <h2>Editar Cliente</h2>

        </div>

         <form asp-action="Editar"
              method="post">

            <input asp-for="ClienteId"
                   type="hidden" />


            <div class="form-group">

                <label>Nombre</label>

                <input asp-for="Nombre"
                       class="form-control" />

            </div>

            <div class="form-group">

                <label>Telefono</label>

                <input asp-for="Telefono"
                       class="form-control" />

            </div>

            <div class="form-group">

                <label>Correo</label>

                <input asp-for="Correo"
                       class="form-control" />

            </div>

            <div class="form-group">

                <label>Estado</label>

                <select asp-for="Estado"
                        class="form-control">

                    @foreach (var estado in Enum.GetValues<EstadoEnum>())
                    {
                        <option value="@estado">
                            @estado
                        </option>
                    }

                </select>

            </div>

            <div class="edit-actions">

                <button type="submit"
                        class="btn-primary">

                    Guardar

                </button>

                <a asp-action="ObtenerClientes"
                   class="btn-secondary">

                    Cancelar

                </a>

            </div>

        </form>

    </div>

</div>

