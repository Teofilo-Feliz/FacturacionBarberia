@model ClienteRequest

@section Styles
{
    <link rel="stylesheet"
          href="~/css/cliente.css" />

}

    <

<div class="cliente-container">

    <div class="cliente-card">

        <h2 class="cliente-title">
            Registrar Cliente
        </h2>

        <form asp-action="Crear" method="post">

            <div asp-validation-summary="ModelOnly"
                 class="validation-errors">
            </div>

            <div class="form-group">
                <label class="form-label">
                    Nombre
                </label>

                <input asp-for="Nombre"
                       class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    Teléfono
                </label>

                <input asp-for="Telefono"
                       class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    Correo
                </label>

                <input asp-for="Correo"
                       class="form-control" />
            </div>

            <div class="button-group">

                <button type="submit"
                        class="btn-primary">
                    Guardar
                </button>

                <a asp-action="Index"
                   class="btn-secondary">
                    Cancelar
                </a>

            </div>

        </form>

    </div>

</div>