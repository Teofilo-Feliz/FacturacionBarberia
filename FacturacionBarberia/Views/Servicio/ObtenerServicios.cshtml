@using FacturacionBarberia.Aplication.ViewModel
@using FacturacionBarberia.Domain.Models.Enum

@model ConsultaViewModel<ObtenerServicioRequest,ObtenerServicioResponse>

<form method="get"
    asp-action="ObtenerServicios">

    <div class="filters-card">

        <h3>Filtros de búsqueda</h3>

        <div class="filters-grid">

            <div class="form-group">
                <label>ID</label>
                <input asp-for="Filtros.ServicioId"
                       class="form-control" />
            </div>

            <div class="form-group">
                <label>Nombre</label>
                <input asp-for="Filtros.Nombre"
                       class="form-control" />
            </div>

            <div class="form-group">
                <label>Precio</label>
                <input asp-for="Filtros.Precio"
                       class="form-control" />
            </div>

            <div class="form-group">

                <label>Estado</label>

                <select asp-for="Filtros.Estado"
                        class="form-control">

                    <option value="">Todos</option>

                    @foreach (var estado in Enum.GetValues<EstadoEnum>())
                    {
                        <option value="@estado">
                            @estado
                        </option>
                    }

                </select>

            </div>

            <div class="actions">

                <button type="submit"
                        class="btn-primary">

                    Buscar

                </button>

                <a asp-action="ObtenerServicios"
                   class="btn-secondary">
                    Limpiar
                </a>
            </div>

        </div>

   </div>



</form>

@if (!Model.Resultados.Any())
    {
        <div class="validation-errors">
            No se encontraron servicios.
        </div>
    }
    else
    {
        <table class="table">

        <thead>

            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var servicio in Model.Resultados)
            {
                <tr>

                    <td>@servicio.ServicioId</td>

                    <td>@servicio.Nombre</td>
                    <td>@servicio.Precio</td>
                    <td>@servicio.Estado</td>

                    <td>
                      @if (User.IsInRole("Administrador"))
                      {
                        <a asp-action="Editar"
                           asp-route-id="@servicio.ServicioId"
                           class="btn-edit">

                            Editar

                        </a>
                      }
                    </td>

                </tr>
            }

        </tbody>

    </table>
}

