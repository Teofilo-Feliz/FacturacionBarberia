@{
    bool esAdmin = User.IsInRole("Administrador");
    bool esCajero = User.IsInRole("Cajero");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>Barber Manager</title>

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/dashboard.css"
          asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>

    <header class="header">

        <div class="logo">
            💈 Barber Manager
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <nav class="nav-menu">

               
                @if (esAdmin)
                {
                    <a asp-controller="Dashboard"
                       asp-action="Index">
                        Dashboard
                    </a>
                }

               
                @if (esAdmin)
                {
                    <div class="dropdown">

                        <a href="#">
                            Usuarios
                        </a>

                        <div class="dropdown-content">

                            <a asp-controller="Usuario"
                               asp-action="Crear">
                                Crear Usuario
                            </a>

                            <a asp-controller="Usuario"
                               asp-action="ObtenerUsuarios">
                                Consultar Usuarios
                            </a>

                        </div>

                    </div>
                }

               
                @if (esAdmin || esCajero)
                {
                    <div class="dropdown">

                        <a href="#">
                            Clientes
                        </a>

                        <div class="dropdown-content">

                            <a asp-controller="Cliente"
                               asp-action="Crear">
                                Crear Cliente
                            </a>

                            <a asp-controller="Cliente"
                               asp-action="ObtenerClientes">
                                Consultar Clientes
                            </a>

                        </div>

                    </div>
                }

                
                @if (esAdmin || esCajero)
                {
                    <div class="dropdown">

                        <a href="#">
                            Servicios
                        </a>

                        <div class="dropdown-content">

                            <a asp-controller="Servicio"
                               asp-action="Crear">
                                Crear Servicio
                            </a>

                            <a asp-controller="Servicio"
                               asp-action="ObtenerServicios">
                                Consultar Servicios
                            </a>

                        </div>

                    </div>
                }

            
                @if (esAdmin || esCajero)
                {
                    <div class="dropdown">

                        <a href="#">
                            Facturas
                        </a>

                        <div class="dropdown-content">

                            <a asp-controller="Factura"
                               asp-action="Crear">
                                Facturar
                            </a>

                            <a asp-controller="Factura"
                               asp-action="ObtenerFacturas">
                                Consultar Facturas
                            </a>

                        </div>

                    </div>
                }

            </nav>

            <div class="header-right">

                <span class="user-name">
                    @User.Identity.Name
                </span>

                <form asp-controller="Login"
                      asp-action="Logout"
                      method="post">

                    <button type="submit"
                            class="btn-logout">
                        Salir
                    </button>

                </form>

            </div>
        }

    </header>

    <main class="main-container">

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert-error">
                @TempData["Error"]
            </div>
        }

        @RenderBody()

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>