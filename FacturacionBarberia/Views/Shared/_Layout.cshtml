<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>Barbería Manager</title>

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    @RenderSection("Styles", required: false)

</head>

<body>

    @{
        var controller =
        ViewContext.RouteData.Values["controller"]?.ToString();
    }

    <header class="header">

        <div class="logo">
            💈 Barbería Manager
        </div>

        <nav class="nav-menu">

            <a asp-controller="Home"
               asp-action="Index">
                Inicio
            </a>

            <div class="dropdown">

                <a href="#">
                    Usuarios 
                </a>

                <div class="dropdown-content">

                    <a asp-controller="Usuario"
                       asp-action="Crear">
                        Crear Usuario
                    </a>

                    <a asp-controller="Usuario"
                       asp-action="ObtenerUsuarios">
                        Consultar Usuarios
                    </a>

                </div>

            </div>

            <div class="dropdown">

                <a href="#">
                    Clientes 
                </a>

                <div class="dropdown-content">

                    <a asp-controller="Cliente"
                       asp-action="Crear">
                        Crear Cliente
                    </a>

                    <a asp-controller="Cliente"
                       asp-action="ObtenerClientes">
                        Consultar Clientes
                    </a>

                </div>

            </div>

            <div class="dropdown">

                <a href="#">
                    Servicio
                </a>

                <div class="dropdown-content">

                    <a asp-controller="Servicio"
                       asp-action="Crear">
                        Crear Servicio
                    </a>

                    <a asp-controller="Servicio"
                       asp-action="ObtenerClientes">
                        Consultar Consultar servicio
                    </a>

                </div>

            </div>

        </nav>


        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="header-right">

                <span class="user-name">

                    @User.Identity.Name

                </span>

                <form asp-controller="Login"
                      asp-action="Logout"
                      method="post">

                    <button type="submit"
                            class="btn-logout">

                        Salir

                    </button>

                </form>

            </div>
        }

    </header>

    <main class="main-container">

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">

                @TempData["Success"]

            </div>
        }

        @RenderBody()

    </main>

    @RenderSection("Scripts", required: false)

</body>
</html>