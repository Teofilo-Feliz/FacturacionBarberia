@model LoginRequest
@{
    Layout = "~/Views/Shared/_LayaoutLogin.cshtml";
}


@section Styles
{
    <link rel="stylesheet"
          href="~/css/login.css"
          />
}

<div class="login-page">

    <div class="login-card">
        <div class="login-h1">
            <img class="mainlogo" src="~/Imagen/mainlogo.png" alt="Alternate Text" />
            <h1>
                Barber Manager
            </h1>
        </div>
        

        <p class="subtext-h1">
            Iniciar Sesión
        </p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-errors">
                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            </div>
        }
        

        <form asp-action="Index"
              method="post">

            <div class="form-group">

                <label>
                    Usuario
                </label>

                <input asp-for="UserName"
                       class="form-control" />

            </div>

            <div class="form-group">

                <label>
                    Contraseña
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-control" />

            </div>

            <button type="submit"
                    class="btn-primary">

                Iniciar Sesión

            </button>

        </form>

      

    </div>

    

</div>