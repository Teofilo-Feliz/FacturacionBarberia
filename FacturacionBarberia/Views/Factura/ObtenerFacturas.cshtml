@model ConsultaViewModel<ObtenerFacturaRequest, ObtenerFacturaResponse>
@using FacturacionBarberia.Aplication.ViewModel
@using FacturacionBarberia.Domain.Models.Enum

{

@{
    ViewData["Title"] = "Consultar Facturas";
}

<div class="container mt-4">

    ```
    <div class="card shadow-sm">
        <div class="card-header">
            <h3>Consulta de Facturas</h3>
        </div>

        <div class="card-body">

            <form asp-action="ObtenerFacturas" method="get">

                <div class="row">

                    <div class="col-md-3 mb-3">
                        <label asp-for="Filtros.FacturaId" class="form-label">
                            Factura
                        </label>
                        <input asp-for="Filtros.FacturaId"
                               class="form-control" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Filtros.Cliente" class="form-label">
                            Cliente
                        </label>
                        <input asp-for="Filtros.Cliente"
                               class="form-control" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Filtros.Usuario" class="form-label">
                            Usuario
                        </label>
                        <input asp-for="Filtros.Usuario"
                               class="form-control" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Filtros.EstadoFactura" class="form-label">
                            Estado
                        </label>

                        <select asp-for="Filtros.EstadoFactura"
                                asp-items="Html.GetEnumSelectList<EstadoFacturaEnum>()"
                                class="form-select">
                            <option value="">Todos</option>
                        </select>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-3 mb-3">
                        <label asp-for="Filtros.FechaDesde" class="form-label">
                            Fecha Desde
                        </label>

                        <input asp-for="Filtros.FechaDesde"
                               type="date"
                               class="form-control" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Filtros.FechaHasta" class="form-label">
                            Fecha Hasta
                        </label>

                        <input asp-for="Filtros.FechaHasta"
                               type="date"
                               class="form-control" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Filtros.FormaPago" class="form-label">
                            Forma de Pago
                        </label>

                        <select asp-for="Filtros.FormaPago"
                                asp-items="Html.GetEnumSelectList<FormaPagoEnum>()"
                                class="form-select">
                            <option value="">Todos</option>
                        </select>
                    </div>

                </div>

                <div class="mt-3">

                    <button type="submit"
                            class="btn btn-primary">
                        Buscar
                    </button>

                    <a asp-action="ObtenerFacturas"
                       class="btn btn-secondary">
                        Limpiar
                    </a>

                    <a asp-action="Crear"
                       class="btn btn-success">
                        Nueva Factura
                    </a>

                </div>

            </form>

        </div>
    </div>

    <div class="card mt-4 shadow-sm">

        <div class="card-body">

            <table class="table table-striped table-hover">

                <thead>

                    <tr>
                        <th>Factura</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th>Usuario</th>
                        <th>Total</th>
                        <th>Forma Pago</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>

                </thead>

                <tbody>

                    @if (Model.Resultados.Any())
                    {
                        @foreach (var item in Model.Resultados)
                        {
                            <tr>

                                <td>@item.FacturaId</td>

                                <td>
                                    @item.FechaFactura.ToString("dd/MM/yyyy")
                                </td>

                                <td>@item.Cliente</td>

                                <td>@item.Usuario</td>

                                <td>
                                    @item.Total.ToString("N2")
                                </td>

                                <td>@item.FormaPago</td>

                                <td>@item.EstadoFactura</td>

                                <td>

                                    <a asp-action="Detalle"
                                       asp-route-facturaId="@item.FacturaId"
                                       class="btn btn-info btn-sm">
                                        Ver
                                    </a>

                                    @if (item.EstadoFactura == EstadoFacturaEnum.Activa)
                                    {
                                        <form asp-action="Anular"
                                              asp-route-facturaId="@item.FacturaId"
                                              method="post"
                                              style="display:inline;">

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm">
                                                Anular
                                            </button>

                                        </form>
                                    }

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8"
                                class="text-center">
                                No se encontraron registros.
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
    ```

</div>
