@using System.Text.Json
@using FacturacionBarberia.Domain.Models.Enum
@using FacturacionBarberia.Aplication.ViewModel

@model CrearFacturaViewModel

<div class="filters-card">

    <h3>Crear Factura</h3>

    <form asp-action="Crear"
          method="post"
          id="facturaForm">

        <div asp-validation-summary="ModelOnly"
             class="validation-errors">
        </div>

        <div class="filters-grid">

            <div class="form-group">

                <label>Cliente</label>

                <select asp-for="Factura.ClienteId" required
                        asp-items="Model.Clientes"
                        class="form-control">

                    <option value="">
                        Seleccione un cliente
                    </option>

                </select>

            </div>

            <div class="form-group">

                <label>Forma de Pago</label>

                <select asp-for="Factura.FormaPago" required
                        class="form-control">

                    <option value="">
                        Seleccione una forma de pago
                    </option>

                    @foreach (var formaPago in Enum.GetValues<FormaPagoEnum>())
                    {
                        <option value="@formaPago">
                            @formaPago
                        </option>
                    }

                </select>

            </div>

        </div>

        <hr />

        

        <div class="filters-grid">

            <div class="form-group">

                <label>Servicio</label>

                <select id="servicioSelect" 
                        class="form-control">

                    <option value="">
                        Seleccione un servicio
                    </option>

                    @foreach (var servicio in Model.ServiciosData)
                    {
                        <option value="@servicio.ServicioId"
                                data-precio="@servicio.Precio"
                                data-nombre="@servicio.Nombre">

                            @servicio.Nombre - RD$ @servicio.Precio

                        </option>
                    }

                </select>

            </div>

            <div class="form-group">

                <label>Cantidad</label>

                <input type="number"
                       id="cantidad"
                       value="1"
                       min="1"
                       class="form-control" />

            </div>

        </div>

        <div class="actions">

            <button type="button"
                    id="btnAgregar"
                    class="btn-primary"
                    style="position: relative; top: -10px;">
                Agregar 

            </button>

        </div>

        <hr />

        <h4>Detalle Factura</h4>

        <table class="table" style="position: relative; top: 10px;">

            <thead>

                <tr>
                    <th>Servicio</th>
                    <th>Precio</th>
                    <th>Cantidad</th>
                    <th>Subtotal</th>
                    <th>Acción</th>
                </tr>

            </thead>

            <tbody id="detalleBody">
            </tbody>

        </table>

        <div class="filters-card">

            <h4>Vista Previa</h4>

            <div style="padding:15px">

                <p>
                    <strong>Total:</strong>
                    RD$
                    <span id="totalFactura">
                        0.00
                    </span>
                </p>

            </div>

        </div>

        <div class="form-group">

            <label>Observaciones</label>

            <textarea asp-for="Factura.Observaciones"
                      rows="4"
                      class="form-control">
            </textarea>

        </div>

        <div id="hiddenInputs">
        </div>

        <div class="actions">

            <button type="submit"
                    class="btn-primary">

                Facturar

            </button>

        </div>

    </form>

</div>

<script>
    let detalles = [];

    document.getElementById('btnAgregar').addEventListener('click', agregarServicio);

    function agregarServicio() {
        const servicio = document.getElementById('servicioSelect');
        const cantidadInput = document.getElementById('cantidad');
        const cantidad = parseInt(cantidadInput.value);
        const option = servicio.options[servicio.selectedIndex];

        if (!option.value) {
            // Reemplazado alert por SweetAlert2
            Swal.fire('Atención', 'Seleccione un servicio válido', 'warning');
            return;
        }

        if (isNaN(cantidad) || cantidad < 1) {
            Swal.fire('Atención', 'La cantidad debe ser mayor o igual a 1', 'warning');
            return;
        }

        const servicioId = parseInt(option.value);
        const existe = detalles.some(x => x.servicioId === servicioId);

        if (existe) {
            // Reemplazado alert por SweetAlert2
            Swal.fire('Atención', 'Ese servicio ya fue agregado a la lista', 'warning');
            return;
        }

        detalles.push({
            servicioId: servicioId,
            nombre: option.dataset.nombre,
            precio: parseFloat(option.dataset.precio),
            cantidad: cantidad
        });

        // Limpiar selección para mejorar UX
        servicio.value = "";
        cantidadInput.value = "1";

        renderTabla();
    }

    function renderTabla() {
        const tbody = document.getElementById('detalleBody');
        const hidden = document.getElementById('hiddenInputs');

        tbody.innerHTML = '';
        hidden.innerHTML = '';

        let total = 0;

        detalles.forEach((item, index) => {
            const subtotal = item.precio * item.cantidad;
            total += subtotal;

            tbody.innerHTML += `
                <tr>
                    <td>${item.nombre}</td>
                    <td>RD$ ${item.precio.toFixed(2)}</td>
                    <td>${item.cantidad}</td>
                    <td>RD$ ${subtotal.toFixed(2)}</td>
                    <td>
                        <button type="button" class="btn-editAnular" onclick="eliminar(${index})">
                            Eliminar
                        </button>
                    </td>
                </tr>
            `;

            hidden.innerHTML += `
                <input type="hidden" name="Factura.Detalles[${index}].ServicioId" value="${item.servicioId}" />
                <input type="hidden" name="Factura.Detalles[${index}].Cantidad" value="${item.cantidad}" />
            `;
        });

        document.getElementById('totalFactura').innerText = total.toFixed(2);
    }

    function eliminar(index) {
        detalles.splice(index, 1);
        renderTabla();
    }

    // Manejador del Submit
    document.getElementById('facturaForm').addEventListener('submit', function (e) {
        e.preventDefault(); // Detiene el envío inmediato
        mostrarConfirmacion();
    });

    function mostrarConfirmacion() {
        // 1. Declarar variables al inicio de la función
        const clienteSelect = document.querySelector('[name="Factura.ClienteId"]');
        const formaPagoSelect = document.querySelector('[name="Factura.FormaPago"]');
        const totalText = document.getElementById('totalFactura').innerText;

        // 2. Validaciones previas
        if (!clienteSelect.value) {
            Swal.fire('Error', 'Debe seleccionar un cliente', 'error');
            return;
        }

        if (!formaPagoSelect.value) {
            Swal.fire('Error', 'Debe seleccionar una forma de pago', 'error');
            return;
        }

        if (detalles.length === 0) {
            Swal.fire('Error', 'Debe agregar al menos un servicio al detalle', 'error');
            return;
        }

        const clienteTexto = clienteSelect.options[clienteSelect.selectedIndex].text;

        // 3. Alerta de confirmación de SweetAlert2
        Swal.fire({
            title: '¿Confirmar Factura?',
            html: `Se generará la factura para <strong>${clienteTexto}</strong> <br> por un total de <strong>RD$ ${totalText}</strong>.`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sí, facturar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                // Envía el formulario programáticamente si el usuario acepta
                document.getElementById('facturaForm').submit();
            }
        });
    }
</script>