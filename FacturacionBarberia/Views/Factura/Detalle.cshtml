@model ObtenerDetalleFacturaResponse
<div class="filters-card">

    <h3>Factura #@Model.FacturaId</h3>

    <div class="filters-grid">

        <div class="form-group">
            <label>Cliente</label>
            <input value="@Model.Cliente"
                   class="form-control"
                   readonly />
        </div>

        <div class="form-group">
            <label>Usuario</label>
            <input value="@Model.Usuario"
                   class="form-control"
                   readonly />
        </div>

        <div class="form-group">
            <label>Fecha</label>
            <input value="@Model.FechaFactura.ToString("dd/MM/yyyy HH:mm")"
                   class="form-control"
                   readonly />
        </div>

        <div class="form-group">
            <label>Estado</label>
            <input value="@Model.Estado.ToString()"
                   class="form-control"
                   readonly />
        </div>

    </div>

</div>

<div class="filters-card">

    <h3>Detalle de Servicios</h3>

    <table class="table">

        <thead>
            <tr>
                <th>Servicio</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>Subtotal</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model.Detalles)
            {
                <tr>

                    <td>@item.Servicio</td>

                    <td>
                        RD$ @item.Precio.ToString("N2")
                    </td>

                    <td>@item.Cantidad</td>

                    <td>
                        RD$ @item.SubTotal.ToString("N2")
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

<div class="filters-card">

    <h3>
        Total Facturado:
        RD$ @Model.Total.ToString("N2")
    </h3>

    <div class="actions">

        <a asp-action="ObtenerFacturas"
           class="btn-secondary">

            Volver

        </a>

        <button onclick="window.print()"
                class="btn-primary">

            Imprimir

        </button>

    </div>

</div>